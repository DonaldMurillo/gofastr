#!/bin/sh
# GoFastr pre-commit hook — CI's "build · vet · test" job, locally.
#
# Runs the same blocking steps as .github/workflows/ci.yml's first job
# (build, gofmt on tracked files, vet, the deterministic test sweep,
# coverage floors) plus a secrets/sensitive-file scan, so a commit that
# would fail CI fails HERE first. Keep the test command in sync with the
# workflow when editing either.
#
# Enable once per clone: make hooks
# Emergency bypass:      git commit --no-verify   (CI still gates)
# Skip only the slow test sweep (e.g. docs-only commit):
#   GOFASTR_SKIP_COMMIT_TESTS=1 git commit ...    (pre-push re-runs it)

set -e

RED='\033[31m'
GREEN='\033[32m'
YELLOW='\033[33m'
NC='\033[0m'

pass() { printf "  ${GREEN}✓${NC} %s\n" "$1"; }
warn() { printf "  ${YELLOW}!${NC} %s\n" "$1"; }
fail() { printf "  ${RED}✗${NC} %s\n" "$1"; }

# Git runs hooks with GIT_DIR / GIT_WORK_TREE / GIT_INDEX_FILE (etc.)
# pointing at THIS repo, and they inherit into every child process. The
# test sweep shells out to `git init` / `git status` in temp dirs
# (gofastr init, the onboarding evals), which would then target this repo
# instead of their fixture and fail. Unset git's own location vars so the
# sweep runs in a clean environment, exactly like CI (which runs tests as
# a plain step, not inside a hook).
unset $(git rev-parse --local-env-vars 2>/dev/null) 2>/dev/null || true

# ---- 1. Build ----
echo ""
go build ./...
pass "go build ./..."

# ---- 2. Format check (tracked files only — gen/ and scratch dirs are
#          not ours to police) ----
gofmt_output=$(git ls-files '*.go' | xargs gofmt -l)
if [ -n "$gofmt_output" ]; then
  fail "Files not formatted:"
  echo "$gofmt_output"
  echo ""
  echo "  Fix: gofmt -w <files>"
  exit 1
fi
pass "Code formatted"

# ---- 3. Secret/credential scanning ----
echo ""
echo "  Scanning for secrets..."

# Get staged files only (what's about to be committed)
staged_files=$(git diff --cached --name-only --diff-filter=ACM | grep -v '^vendor/' || true)

if [ -n "$staged_files" ]; then
  # Patterns that look like secrets
  secret_patterns="
password[[:space:]]*[:=][[:space:]]*['\"][^'\"]{6,}['\"]
secret[_-]?key[[:space:]]*[:=][[:space:]]*['\"][^'\"]{8,}['\"]
api[_-]?key[[:space:]]*[:=][[:space:]]*['\"][^'\"]{8,}['\"]
private[_-]?key[[:space:]]*[:=][[:space:]]*['\"][^'\"]{8,}['\"]
token[[:space:]]*[:=][[:space:]]*['\"][^'\"]{8,}['\"]
BEGIN[[:space:]]+RSA[[:space:]]+PRIVATE[[:space:]]+KEY
BEGIN[[:space:]]+PRIVATE[[:space:]]+KEY
BEGIN[[:space:]]+OPENSSH[[:space:]]+PRIVATE[[:space:]]+KEY
-----BEGIN PGP-----
AKIA[0-9A-Z]{16}
sk_live_[0-9a-zA-Z]{24,}
sk_test_[0-9a-zA-Z]{24,}
ghp_[0-9a-zA-Z]{36}
gho_[0-9a-zA-Z]{36}
xox[boap]-[0-9a-zA-Z-]{10,}
hooks\.slack\.com/services/T[A-Z0-9]{9,}/B[A-Z0-9]{9,}/[a-zA-Z0-9]{24}
eyJ[a-zA-Z0-9]{20,}\.eyJ[a-zA-Z0-9]{20,}\.[a-zA-Z0-9]{10,}
"

  found_secrets=""
  for file in $staged_files; do
    if [ ! -f "$file" ]; then continue; fi
    # Skip binary files
    if file "$file" | grep -q "binary\|image\|data"; then continue; fi
    # Skip go.sum (hashes look like secrets) and hook scripts (contain detection patterns)
    case "$file" in go.sum|*.lock|.githooks/*|Makefile) continue ;; esac

    for pattern in $secret_patterns; do
      [ -z "$pattern" ] && continue
      # A line carrying "not-a-secret: <why>" is a reviewed false
      # positive (e.g. code that RENDERS an env template, test
      # fixtures). The annotation lives in the diff, so every
      # exemption is visible to review — unlike --no-verify, which
      # skips every check invisibly and is banned.
      matches=$(grep -n -i -E "$pattern" "$file" 2>/dev/null | grep -v "not-a-secret:" || true)
      if [ -n "$matches" ]; then
        found_secrets="$found_secrets\n  $file:\n$matches"
      fi
    done
  done

  if [ -n "$found_secrets" ]; then
    echo ""
    fail "POTENTIAL SECRETS DETECTED!"
    printf "$found_secrets\n"
    echo ""
    echo "  Real secret → move it to the environment / .env (gitignored)."
    echo "  False positive → annotate the flagged line with a comment:"
    echo "    // not-a-secret: <why this line is safe>"
    echo "  Do NOT use --no-verify."
    echo ""
    exit 1
  fi
fi
pass "No secrets detected"

# ---- 4. Sensitive file check ----
echo ""
for file in $staged_files; do
  case "$file" in
    *.env|*.env.*|.env|credentials*|*.pem|*.key|*.p12|*.pfx|id_rsa*|id_ed25519*)
      fail "Sensitive file in commit: $file"
      echo "  If intentional: git commit --no-verify"
      exit 1
      ;;
  esac
done
pass "No sensitive files"

# ---- 5. go vet ----
echo ""
go vet ./...
pass "go vet clean"

# ---- 6. Deterministic test sweep + coverage floors (CI-identical) ----
echo ""
if [ "${GOFASTR_SKIP_COMMIT_TESTS:-}" = "1" ]; then
  warn "test sweep skipped (GOFASTR_SKIP_COMMIT_TESTS=1) — pre-push and CI still gate"
else
  echo "  → Deterministic test sweep (mirrors CI's blocking job)..."
  # No -count=1: Go's cached PASSes make repeat commits on unchanged
  # packages near-instant (same content-addressed cache CI now relies on).
  # shellcheck disable=SC2046  # word splitting of go list output is intended
  go test -timeout=20m -p 2 \
    -skip 'TestBlueprintCLIGeneratesEntireWorkingAppE2E|TestE2E_HotReload_BrowserAutoRefreshes|TestLivereloadSameBuildIDDoesNotReload' \
    $(go list ./... | grep -vE 'gofastr/(examples/site|examples/meridian|kiln/integration|core-ui/runtime|core-ui/widget|evals/ui-quality/internal/evalrunner)$')
  pass "Deterministic tests passed"

  echo ""
  bash scripts/coverage-floors.sh
  pass "Coverage floors hold"
fi

echo ""
pass "All pre-commit checks passed"
echo ""
