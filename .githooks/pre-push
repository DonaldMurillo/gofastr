#!/bin/sh
# GoFastr pre-push hook — safety net behind pre-commit.
#
# Re-runs the deterministic CI test sweep when a commit skipped it
# (GOFASTR_SKIP_COMMIT_TESTS=1 or --no-verify), then module integrity and
# govulncheck. The old `go test -race ./...` is gone: it took half an
# hour and swept the packages CI deliberately excludes as flaky-by-design
# (core-ui/runtime, core-ui/widget, examples/site) — use `make test-race`
# for a deliberate race pass.
#
# Enable once per clone: make hooks
# Skip the sweep once (CI still gates): GOFASTR_SKIP_PUSH_TESTS=1 git push

set -e

RED='\033[31m'
GREEN='\033[32m'
YELLOW='\033[33m'
NC='\033[0m'

pass() { printf "  ${GREEN}✓${NC} %s\n" "$1"; }
warn() { printf "  ${YELLOW}!${NC} %s\n" "$1"; }
fail() { printf "  ${RED}✗${NC} %s\n" "$1"; }

echo ""
echo "  Pre-push gate..."
echo ""

# ---- 1. Deterministic test sweep (CI-identical; keep in sync with
#          .github/workflows/ci.yml and .githooks/pre-commit) ----
if [ "${GOFASTR_SKIP_PUSH_TESTS:-}" = "1" ]; then
  warn "test sweep skipped (GOFASTR_SKIP_PUSH_TESTS=1) — CI still gates"
else
  echo "  → Deterministic test sweep (several minutes)..."
  # shellcheck disable=SC2046  # word splitting of go list output is intended
  go test -count=1 -timeout=20m -p 2 \
    -skip 'TestBlueprintCLIGeneratesEntireWorkingAppE2E|TestE2E_HotReload_BrowserAutoRefreshes|TestLivereloadSameBuildIDDoesNotReload' \
    $(go list ./... | grep -vE 'gofastr/(examples/site|examples/meridian|kiln/integration|core-ui/runtime|core-ui/widget|evals/ui-quality/internal/evalrunner)$')
  pass "Deterministic tests passed"

  echo ""
  bash scripts/coverage-floors.sh
  pass "Coverage floors hold"
fi

# ---- 2. Vulnerability check ----
echo ""
if command -v govulncheck >/dev/null 2>&1; then
  echo "  → Running govulncheck..."
  if govulncheck ./...; then
    pass "No known vulnerabilities"
  else
    fail "Vulnerabilities found!"
    echo ""
    echo "  Install: go install golang.org/x/vuln/cmd/govulncheck@latest"
    exit 1
  fi
else
  warn "govulncheck not installed (optional)"
  echo "    Install: go install golang.org/x/vuln/cmd/govulncheck@latest"
fi

# ---- 3. Module integrity ----
echo ""
echo "  → Checking go.sum integrity..."
go mod verify
pass "Module integrity verified"

echo ""
pass "Pre-push checks passed"
echo ""
