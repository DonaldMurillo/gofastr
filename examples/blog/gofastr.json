{
  "app": {
    "name": "blog",
    "port": 8080,
    "database": {
      "driver": "postgres",
      "dsn": "postgres://user:password@localhost:5432/blog?sslmode=disable"
    }
  },

  "middleware": {
    "cors": {
      "allowedOrigins": ["*"],
      "allowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allowedHeaders": ["Content-Type", "Authorization"]
    },
    "auth": {
      "routes": ["POST", "PUT", "DELETE"],
      "strategy": "bearer"
    }
  },

  "entities": {
    "users": {
      "table": "users",
      "timestamps": true,
      "fields": [
        { "name": "name",     "type": "string",  "required": true },
        { "name": "email",    "type": "string",  "required": true, "unique": true },
        { "name": "role",     "type": "enum",    "values": ["admin", "author", "reader"], "default": "reader" },
        { "name": "avatar",   "type": "file" }
      ],
      "relations": [
        { "type": "hasMany", "name": "posts",    "entity": "posts",    "foreignKey": "author_id" },
        { "type": "hasMany", "name": "comments", "entity": "comments", "foreignKey": "author_id" }
      ],
      "crud": true,
      "mcp": true
    },

    "posts": {
      "table": "posts",
      "timestamps": true,
      "softDelete": true,
      "fields": [
        { "name": "title",        "type": "string",    "required": true },
        { "name": "body",         "type": "text" },
        { "name": "status",       "type": "enum",      "values": ["draft", "published"], "default": "draft" },
        { "name": "author_id",    "type": "relation",  "to": "users" },
        { "name": "published_at", "type": "timestamp" }
      ],
      "relations": [
        { "type": "hasMany",   "name": "comments", "entity": "comments", "foreignKey": "post_id" },
        { "type": "belongsTo", "name": "author",   "entity": "users",    "foreignKey": "author_id" }
      ],
      "crud": true,
      "mcp": true
    },

    "comments": {
      "table": "comments",
      "timestamps": true,
      "fields": [
        { "name": "body",      "type": "text",     "required": true },
        { "name": "post_id",   "type": "relation", "to": "posts" },
        { "name": "author_id", "type": "relation", "to": "users" }
      ],
      "relations": [
        { "type": "belongsTo", "name": "post",   "entity": "posts", "foreignKey": "post_id" },
        { "type": "belongsTo", "name": "author", "entity": "users", "foreignKey": "author_id" }
      ],
      "crud": true,
      "mcp": true
    }
  },

  "endpoints": {
    "custom": [
      {
        "method": "GET",
        "path": "/posts/published",
        "description": "List only published posts (auto-filters status=published)",
        "handler": "posts.list",
        "filter": { "status": "published" }
      },
      {
        "method": "GET",
        "path": "/posts/search",
        "description": "Search posts by keyword",
        "params": [{ "name": "q", "type": "string", "required": true }],
        "mcp": true
      }
    ]
  }
}
