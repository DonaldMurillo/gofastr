// TabItem is a single tab: a label for the button and HTML content for
// the panel.
type TabItem struct {
	Label   string
	Content render.HTML
}

// TabsConfig configures a signal-driven tab strip with content panels.
type TabsConfig struct {
	// SignalName is the signal that holds the active tab index as a
	// string. Required.
	SignalName string
	// Tabs is the list of tab items. At least one is required.
	Tabs []TabItem
	// Class is an optional extra CSS class on the outer wrapper.
	Class string
}

// tabsStyle is the registered CSS for fui-tabs.
var tabsStyle = registry.RegisterStyle("fui-tabs", tabsCSS)

